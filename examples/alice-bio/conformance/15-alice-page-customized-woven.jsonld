{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ns#",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "targetsFileExpectation": {
      "@type": "@id"
    },
    "ignorePredicate": {
      "@type": "@id"
    }
  },
  "type": "Manifest",
  "id": "urn:accord:semantic-flow:alice-bio:15-alice-page-customized-woven",
  "dcterms:title": "Alice Bio 15 alice page customized woven",
  "dcterms:description": "Checks the weave over Alice's page-definition support artifact, including first history/state materialization for _knop/_page, an advanced Alice KnopInventory state, and an updated alice/index.html that follows the customized page definition.",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#weave-alice-page-definition",
      "dcterms:title": "Weave Alice page-definition support artifact",
      "dcterms:description": "Versions alice/_knop/_page as a normal support artifact, generates support-artifact pages for the page definition, advances alice/_knop/_inventory to register the new page-definition history, updates alice/index.html to the customized rendering, and keeps _mesh/_inventory unchanged.",
      "fixtureRepo": "github.com/semantic-flow/mesh-alice-bio",
      "operationId": "weave",
      "fromRef": "14-alice-page-customized",
      "toRef": "15-alice-page-customized-woven",
      "targetDesignatorPath": "alice",
      "hasFileExpectation": [
        {
          "id": "#alice-knop-page-definition-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/page.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-main-md",
          "type": "FileExpectation",
          "path": "alice/alice.md",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#mesh-sidebar-md",
          "type": "FileExpectation",
          "path": "mesh-content/sidebar.md",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-asset-css",
          "type": "FileExpectation",
          "path": "alice/_knop/_assets/alice.css",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-definition-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-history-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-s1-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/_s0001/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-s1-manifestation-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/_s0001/page-ttl/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-s1-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/_s0001/page-ttl/page.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/inventory.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-inventory-history-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/index.html",
          "changeType": "updated",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-inventory-s3-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/_s0003/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-inventory-s3-manifestation-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/_s0003/inventory-ttl/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-inventory-s3-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/_s0003/inventory-ttl/inventory.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page",
          "type": "FileExpectation",
          "path": "alice/index.html",
          "changeType": "updated",
          "compareMode": "text"
        },
        {
          "id": "#mesh-inventory-ttl",
          "type": "FileExpectation",
          "path": "_mesh/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page-public-css",
          "type": "FileExpectation",
          "path": "alice/_assets/alice.css",
          "changeType": "absent"
        },
        {
          "id": "#alice-page-subtree-css",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_assets/alice.css",
          "changeType": "absent"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#alice-knop-page-definition-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-page-definition-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page> <https://semantic-flow.github.io/ontology/core/hasPageRegion> ?mainRegion, ?sidebarRegion . ?mainRegion <https://semantic-flow.github.io/ontology/core/regionKey> \"main\" . ?sidebarRegion <https://semantic-flow.github.io/ontology/core/regionKey> \"sidebar\" . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#main-file> <https://semantic-flow.github.io/ontology/core/workspaceRelativePath> \"alice/alice.md\" . <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#sidebar-file> <https://semantic-flow.github.io/ontology/core/workspaceRelativePath> \"mesh-content/sidebar.md\" . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-knop-page-s1-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-page-s1-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page> a <https://semantic-flow.github.io/ontology/core/ResourcePageDefinition> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#main-file> <https://semantic-flow.github.io/ontology/core/workspaceRelativePath> \"alice/alice.md\" . <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#sidebar-file> <https://semantic-flow.github.io/ontology/core/workspaceRelativePath> \"mesh-content/sidebar.md\" . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop> <https://semantic-flow.github.io/ontology/core/hasResourcePageDefinition> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page> ; <https://semantic-flow.github.io/ontology/core/hasKnopAssetBundle> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_assets> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page> <https://semantic-flow.github.io/semantic-flow-ontology/hasArtifactHistory> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001> ; <https://semantic-flow.github.io/semantic-flow-ontology/currentArtifactHistory> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasWorkingLocatedFile> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/page.ttl> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasResourcePage> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/index.html> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001/_s0001> . <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001/_s0001> <https://semantic-flow.github.io/semantic-flow-ontology/hasManifestation> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001/_s0001/page-ttl> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001/_s0003> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-knop-inventory-s3-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-inventory-s3-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001/_s0003> <https://semantic-flow.github.io/semantic-flow-ontology/previousHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001/_s0002> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page> <https://semantic-flow.github.io/semantic-flow-ontology/hasArtifactHistory> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001> . }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
}
