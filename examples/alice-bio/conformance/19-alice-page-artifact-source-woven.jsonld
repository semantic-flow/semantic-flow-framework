{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ns#",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "targetsFileExpectation": {
      "@type": "@id"
    },
    "ignorePredicate": {
      "@type": "@id"
    }
  },
  "type": "Manifest",
  "id": "urn:accord:semantic-flow:alice-bio:19-alice-page-artifact-source-woven",
  "dcterms:title": "Alice Bio 19 alice page artifact source woven",
  "dcterms:description": "Checks the weave over Alice's artifact-backed page-definition revision, including the second _page historical state, an advanced Alice KnopInventory state, and an updated alice/index.html that now follows the governed Markdown source through the main page region while mesh inventory remains unchanged.",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#weave-alice-page-artifact-source",
      "dcterms:title": "Weave Alice artifact-backed page-definition revision",
      "dcterms:description": "Versions the updated Alice ResourcePageDefinition into a second historical state, advances Alice Knop inventory history, and updates alice/index.html to render the main region from alice/page-main's current working surface without widening mesh inventory further.",
      "fixtureRepo": "github.com/semantic-flow/mesh-alice-bio",
      "operationId": "weave",
      "fromRef": "18-alice-page-artifact-source",
      "toRef": "19-alice-page-artifact-source-woven",
      "targetDesignatorPath": "alice",
      "hasFileExpectation": [
        {
          "id": "#alice-knop-page-definition-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/page.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page-main-md",
          "type": "FileExpectation",
          "path": "alice-page-main.md",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#mesh-inventory-ttl",
          "type": "FileExpectation",
          "path": "_mesh/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page-main-page",
          "type": "FileExpectation",
          "path": "alice/page-main/index.html",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-definition-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/index.html",
          "changeType": "updated",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-history-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/index.html",
          "changeType": "updated",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-s1-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/_s0001/page-ttl/page.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-page-s2-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/_s0002/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-s2-manifestation-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/_s0002/page-ttl/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-s2-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/_s0002/page-ttl/page.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/inventory.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-inventory-history-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/index.html",
          "changeType": "updated",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-inventory-s4-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/_s0004/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-inventory-s4-manifestation-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/_s0004/inventory-ttl/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-inventory-s4-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/_s0004/inventory-ttl/inventory.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page",
          "type": "FileExpectation",
          "path": "alice/index.html",
          "changeType": "updated",
          "compareMode": "text"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#alice-knop-page-definition-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-page-definition-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#main-source> <https://semantic-flow.github.io/ontology/core/hasTargetArtifact> <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main> ; <https://semantic-flow.github.io/ontology/core/hasArtifactResolutionMode> <https://semantic-flow.github.io/ontology/core/ArtifactResolutionMode/Current> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#sidebar-source> <https://semantic-flow.github.io/ontology/core/targetMeshPath> \"mesh-content/sidebar.md\" . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-knop-page-s2-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-page-s2-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#main-source> <https://semantic-flow.github.io/ontology/core/hasTargetArtifact> <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001/_s0002> . <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001/_s0004> . }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
}
