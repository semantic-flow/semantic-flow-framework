{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ns#",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "targetsFileExpectation": {
      "@type": "@id"
    },
    "ignorePredicate": {
      "@type": "@id"
    }
  },
  "type": "Manifest",
  "id": "urn:accord:semantic-flow:alice-bio:06-alice-bio-integrated",
  "dcterms:title": "Alice Bio 06 alice bio integrated",
  "dcterms:description": "Checks the first payload integration step, keeping the working Turtle bytes at the root while associating them with the new alice/bio payload artifact.",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#integrate-alice-bio",
      "dcterms:title": "Integrate alice/bio payload artifact",
      "dcterms:description": "Adds the alice/bio payload artifact and its Knop support artifacts, updates mesh inventory, and keeps woven page generation deferred to the next branch.",
      "fixtureRepo": "github.com/semantic-flow/mesh-alice-bio",
      "operationId": "integrate",
      "fromRef": "05-alice-knop-created-woven",
      "toRef": "06-alice-bio-integrated",
      "targetDesignatorPath": "alice/bio",
      "hasFileExpectation": [
        {
          "id": "#alice-bio-ttl",
          "type": "FileExpectation",
          "path": "alice-bio.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#mesh-inventory-ttl",
          "type": "FileExpectation",
          "path": "_mesh/_inventory/inventory.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-bio-knop-meta-ttl",
          "type": "FileExpectation",
          "path": "alice/bio/_knop/_meta/meta.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-bio-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/bio/_knop/_inventory/inventory.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-bio-page",
          "type": "FileExpectation",
          "path": "alice/bio/index.html",
          "changeType": "absent"
        },
        {
          "id": "#alice-bio-knop-page",
          "type": "FileExpectation",
          "path": "alice/bio/_knop/index.html",
          "changeType": "absent"
        },
        {
          "id": "#alice-bio-knop-meta-page",
          "type": "FileExpectation",
          "path": "alice/bio/_knop/_meta/index.html",
          "changeType": "absent"
        },
        {
          "id": "#alice-bio-knop-inventory-page",
          "type": "FileExpectation",
          "path": "alice/bio/_knop/_inventory/index.html",
          "changeType": "absent"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#alice-bio-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-bio-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice> a <https://schema.org/Person> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice> <http://xmlns.com/foaf/0.1/knows> <https://semantic-flow.github.io/mesh-alice-bio/bob> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#mesh-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#mesh-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/_mesh> <https://semantic-flow.github.io/semantic-flow-ontology/hasKnop> <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_knop> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/bio> a <https://semantic-flow.github.io/semantic-flow-ontology/PayloadArtifact>, <https://semantic-flow.github.io/semantic-flow-ontology/DigitalArtifact>, <https://semantic-flow.github.io/semantic-flow-ontology/RdfDocument> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasWorkingLocatedFile> <https://semantic-flow.github.io/mesh-alice-bio/alice-bio.ttl> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_knop> <https://semantic-flow.github.io/semantic-flow-ontology/hasWorkingKnopInventoryFile> <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_knop/_inventory/inventory.ttl> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-bio-knop-meta-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-bio-knop-meta-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_knop> <https://semantic-flow.github.io/semantic-flow-ontology/designatorPath> \"alice/bio\" ; <https://semantic-flow.github.io/semantic-flow-ontology/hasWorkingKnopInventoryFile> <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_knop/_inventory/inventory.ttl> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-bio-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-bio-knop-inventory-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_knop> <https://semantic-flow.github.io/semantic-flow-ontology/hasKnopMetadata> <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_knop/_meta> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasKnopInventory> <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_knop/_inventory> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasPayloadArtifact> <https://semantic-flow.github.io/mesh-alice-bio/alice/bio> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice-bio.ttl> a <https://semantic-flow.github.io/semantic-flow-ontology/LocatedFile>, <https://semantic-flow.github.io/semantic-flow-ontology/RdfDocument> . }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
}
