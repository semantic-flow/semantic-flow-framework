{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ns#",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "targetsFileExpectation": {
      "@type": "@id"
    },
    "ignorePredicate": {
      "@type": "@id"
    }
  },
  "type": "Manifest",
  "id": "urn:accord:semantic-flow:alice-bio:16-alice-page-main-integrated",
  "dcterms:title": "Alice Bio 16 alice page main integrated",
  "dcterms:description": "Checks the non-woven step that introduces a governed Markdown payload artifact for later page use without yet repointing Alice's page definition away from its direct mesh-local Markdown source.",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#integrate-alice-page-main",
      "dcterms:title": "Integrate alice/page-main Markdown payload artifact",
      "dcterms:description": "Adds the governed alice/page-main payload artifact with current working file alice-page-main.md, updates mesh inventory, and leaves Alice's customized page definition and public page unchanged until a later page-source repoint.",
      "fixtureRepo": "github.com/semantic-flow/mesh-alice-bio",
      "operationId": "integrate",
      "fromRef": "15-alice-page-customized-woven",
      "toRef": "16-alice-page-main-integrated",
      "targetDesignatorPath": "alice/page-main",
      "hasFileExpectation": [
        {
          "id": "#alice-page-main-md",
          "type": "FileExpectation",
          "path": "alice-page-main.md",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#mesh-inventory-ttl",
          "type": "FileExpectation",
          "path": "_mesh/_inventory/inventory.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page-main-knop-meta-ttl",
          "type": "FileExpectation",
          "path": "alice/page-main/_knop/_meta/meta.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page-main-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/page-main/_knop/_inventory/inventory.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-page-definition-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/page.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page",
          "type": "FileExpectation",
          "path": "alice/index.html",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#alice-page-main-page",
          "type": "FileExpectation",
          "path": "alice/page-main/index.html",
          "changeType": "absent"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#alice-knop-page-definition-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-page-definition-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#main-source> <https://semantic-flow.github.io/ontology/core/targetMeshPath> \"alice/alice.md\" . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#main-source> <https://semantic-flow.github.io/ontology/core/hasTargetArtifact> <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main> . }",
              "expectedBoolean": false
            }
          ]
        },
        {
          "id": "#mesh-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#mesh-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/_mesh> <https://semantic-flow.github.io/semantic-flow-ontology/hasKnop> <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main/_knop> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main> a <https://semantic-flow.github.io/semantic-flow-ontology/PayloadArtifact>, <https://semantic-flow.github.io/semantic-flow-ontology/DigitalArtifact> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasWorkingLocatedFile> <https://semantic-flow.github.io/mesh-alice-bio/alice-page-main.md> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main> <https://semantic-flow.github.io/semantic-flow-ontology/hasArtifactHistory> ?history . }",
              "expectedBoolean": false
            }
          ]
        },
        {
          "id": "#alice-page-main-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-page-main-knop-inventory-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main/_knop> <https://semantic-flow.github.io/semantic-flow-ontology/hasKnopMetadata> <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main/_knop/_meta> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasKnopInventory> <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main/_knop/_inventory> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasPayloadArtifact> <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main> . }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
}
