{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ns#",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "targetsFileExpectation": {
      "@type": "@id"
    },
    "ignorePredicate": {
      "@type": "@id"
    }
  },
  "type": "Manifest",
  "id": "urn:accord:semantic-flow:alice-bio:18-alice-page-artifact-source",
  "dcterms:title": "Alice Bio 18 alice page artifact source",
  "dcterms:description": "Checks the non-woven step that repoints Alice's main page region from a direct mesh-local Markdown source to the already-woven governed Markdown artifact alice/page-main while leaving public page output unchanged until weave runs.",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#repoint-alice-page-main-source-to-governed-markdown-artifact",
      "dcterms:title": "Repoint Alice main page region to a governed Markdown artifact",
      "dcterms:description": "Updates alice/_knop/_page/page.ttl so the main region resolves through hasTargetArtifact <alice/page-main> in Current mode, keeps the shared sidebar on its mesh-local Markdown source, and leaves woven page-definition history untouched until the next weave.",
      "fixtureRepo": "github.com/semantic-flow/mesh-alice-bio",
      "operationId": "resourcePage.define",
      "fromRef": "17-alice-page-main-integrated-woven",
      "toRef": "18-alice-page-artifact-source",
      "targetDesignatorPath": "alice",
      "hasFileExpectation": [
        {
          "id": "#alice-knop-page-definition-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/page.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page-main-md",
          "type": "FileExpectation",
          "path": "alice-page-main.md",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#alice-main-md",
          "type": "FileExpectation",
          "path": "alice/alice.md",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#mesh-sidebar-md",
          "type": "FileExpectation",
          "path": "mesh-content/sidebar.md",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#mesh-inventory-ttl",
          "type": "FileExpectation",
          "path": "_mesh/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page-main-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/page-main/_knop/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-page-definition-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/index.html",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-page-s1-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_page/_history001/_s0001/page-ttl/page.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-page",
          "type": "FileExpectation",
          "path": "alice/index.html",
          "changeType": "unchanged",
          "compareMode": "text"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#alice-knop-page-definition-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-page-definition-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#main-source> a <https://semantic-flow.github.io/ontology/core/ResourcePageSource> ; <https://semantic-flow.github.io/ontology/core/hasTargetArtifact> <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main> ; <https://semantic-flow.github.io/ontology/core/hasArtifactResolutionMode> <https://semantic-flow.github.io/ontology/core/ArtifactResolutionMode/Current> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#main-source> <https://semantic-flow.github.io/ontology/core/targetMeshPath> \"alice/alice.md\" . }",
              "expectedBoolean": false
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page#sidebar-source> a <https://semantic-flow.github.io/ontology/core/ResourcePageSource> ; <https://semantic-flow.github.io/ontology/core/targetMeshPath> \"mesh-content/sidebar.md\" . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-page-main-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-page-main-knop-inventory-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main> <https://semantic-flow.github.io/semantic-flow-ontology/hasArtifactHistory> <https://semantic-flow.github.io/mesh-alice-bio/alice/page-main/_history001> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_page/_history001/_s0001> . <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001/_s0003> . }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
}
