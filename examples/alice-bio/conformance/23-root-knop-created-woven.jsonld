    {
      "type": "TransitionCase",
      "id": "#weave-root-knop-created",
      "dcterms:title": "Weave root Knop state",
      "dcterms:description": "Versions the root Knop support artifacts, advances the mesh inventory to a sixth historical state, and generates root-facing ResourcePages while leaving root page customization for the later 24/25 pair.",
