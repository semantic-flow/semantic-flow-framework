  "type": "Manifest",
  "id": "urn:accord:semantic-flow:alice-bio:10-alice-bio-updated",
  "dcterms:title": "Alice Bio 10 alice bio updated",
  "dcterms:description": "Checks the non-woven payload update after 09, where the working alice-bio.ttl content changes while the existing woven support surface and first payload snapshot remain unchanged.",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#update-alice-bio-payload",
      "dcterms:title": "Update alice bio payload without weaving",
      "dcterms:description": "Updates the working alice-bio.ttl payload to use explicit base-root IRIs, add authorship of the bio artifact, and expand Bob into a local Person description, while leaving inventories, references, and the first historical payload snapshot unchanged until the next weave.",
      "fixtureRepo": "github.com/semantic-flow/mesh-alice-bio",
      "operationId": "payload.update",
      "fromRef": "09-alice-bio-referenced-woven",
      "toRef": "10-alice-bio-updated",
      "targetDesignatorPath": "alice/bio",
      "hasFileExpectation": [
        {
          "id": "#alice-bio-ttl",
          "type": "FileExpectation",
          "path": "alice-bio.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-bio-s1-ttl",
          "type": "FileExpectation",
          "path": "alice/bio/_history001/_s0001/alice-bio-ttl/alice-bio.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#mesh-inventory-ttl",
          "type": "FileExpectation",
          "path": "_mesh/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-references-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_references/references.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-bio-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/bio/_knop/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#alice-bio-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-bio-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice> a <https://schema.org/Person> ; <http://xmlns.com/foaf/0.1/name> \"Alice\" ; <https://schema.org/birthDate> \"1990-01-15\"^^<http://www.w3.org/2001/XMLSchema#date> ; <http://xmlns.com/foaf/0.1/knows> <https://semantic-flow.github.io/mesh-alice-bio/bob> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/bio> <http://purl.org/dc/terms/creator> <https://semantic-flow.github.io/mesh-alice-bio/alice> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob> a <https://schema.org/Person> ; <http://xmlns.com/foaf/0.1/givenName> \"Robert\" ; <http://xmlns.com/foaf/0.1/nick> \"Bob\" . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-bio-s1-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-bio-s1-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob> a <https://schema.org/Person> . }",
              "expectedBoolean": false
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/bio> <http://purl.org/dc/terms/creator> <https://semantic-flow.github.io/mesh-alice-bio/alice> . }",
              "expectedBoolean": false
            }
          ]
        },
        {
          "id": "#mesh-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#mesh-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/_mesh/_inventory/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/_mesh/_inventory/_history001/_s0003> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-knop-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/_history001/_s0002> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-references-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-references-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice> <https://semantic-flow.github.io/semantic-flow-ontology/hasReferenceLink> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_references#reference001> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#alice-bio-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-bio-knop-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/alice/bio/_history001/_s0001> . }",
              "expectedBoolean": true
