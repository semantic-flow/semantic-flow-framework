{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ns#",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "targetsFileExpectation": {
      "@type": "@id"
    },
    "ignorePredicate": {
      "@type": "@id"
    }
  },
  "type": "Manifest",
  "id": "urn:accord:semantic-flow:alice-bio:21-bob-page-imported-source-woven",
  "dcterms:title": "Alice Bio 21 bob page imported source woven",
  "dcterms:description": "Checks the weave over Bob's imported-source-backed page-definition revision, including Bob's first _page historical state, an advanced Bob KnopInventory state, and an updated bob/index.html that now follows the governed imported Markdown artifact while the imported artifact itself remains unwoven.",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#weave-bob-imported-page-source",
      "dcterms:title": "Weave Bob imported-source page definition",
      "dcterms:description": "Versions Bob's ResourcePageDefinition into its first historical state, advances Bob Knop inventory history, and updates bob/index.html to render the main region from bob/page-main's current local working file while leaving the imported artifact itself unwoven.",
      "fixtureRepo": "github.com/semantic-flow/mesh-alice-bio",
      "operationId": "weave",
      "fromRef": "20-bob-page-imported-source",
      "toRef": "21-bob-page-imported-source-woven",
      "targetDesignatorPath": "bob",
      "hasFileExpectation": [
        {
          "id": "#bob-page-main-md",
          "type": "FileExpectation",
          "path": "bob-page-main.md",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#mesh-inventory-ttl",
          "type": "FileExpectation",
          "path": "_mesh/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-page-main-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "bob/page-main/_knop/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-page-main-page",
          "type": "FileExpectation",
          "path": "bob/page-main/index.html",
          "changeType": "absent"
        },
        {
          "id": "#bob-knop-page-definition-ttl",
          "type": "FileExpectation",
          "path": "bob/_knop/_page/page.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-knop-page-definition-page",
          "type": "FileExpectation",
          "path": "bob/_knop/_page/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#bob-knop-page-history-page",
          "type": "FileExpectation",
          "path": "bob/_knop/_page/_history001/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#bob-knop-page-s1-page",
          "type": "FileExpectation",
          "path": "bob/_knop/_page/_history001/_s0001/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#bob-knop-page-s1-manifestation-page",
          "type": "FileExpectation",
          "path": "bob/_knop/_page/_history001/_s0001/page-ttl/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#bob-knop-page-s1-ttl",
          "type": "FileExpectation",
          "path": "bob/_knop/_page/_history001/_s0001/page-ttl/page.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "bob/_knop/_inventory/inventory.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-knop-inventory-history-page",
          "type": "FileExpectation",
          "path": "bob/_knop/_inventory/_history001/index.html",
          "changeType": "updated",
          "compareMode": "text"
        },
        {
          "id": "#bob-knop-inventory-s2-page",
          "type": "FileExpectation",
          "path": "bob/_knop/_inventory/_history001/_s0002/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#bob-knop-inventory-s2-manifestation-page",
          "type": "FileExpectation",
          "path": "bob/_knop/_inventory/_history001/_s0002/inventory-ttl/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#bob-knop-inventory-s2-ttl",
          "type": "FileExpectation",
          "path": "bob/_knop/_inventory/_history001/_s0002/inventory-ttl/inventory.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-page",
          "type": "FileExpectation",
          "path": "bob/index.html",
          "changeType": "updated",
          "compareMode": "text"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#bob-knop-page-definition-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#bob-knop-page-definition-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page#main-source> <https://semantic-flow.github.io/ontology/core/hasTargetArtifact> <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main> ; <https://semantic-flow.github.io/ontology/core/hasArtifactResolutionMode> <https://semantic-flow.github.io/ontology/core/ArtifactResolutionMode/Current> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#bob-knop-page-s1-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#bob-knop-page-s1-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page#main-source> <https://semantic-flow.github.io/ontology/core/hasTargetArtifact> <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#mesh-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#mesh-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/_mesh/_inventory/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/_mesh/_inventory/_history001/_s0005> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main> <https://semantic-flow.github.io/ontology/core/workingAccessUrl> \"https://raw.githubusercontent.com/djradon/public-notes/refs/heads/main/user.bob-newhart.md\" . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#bob-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#bob-knop-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page/_history001/_s0001> . <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_inventory/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_inventory/_history001/_s0002> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop> <https://semantic-flow.github.io/ontology/core/hasResourcePageDefinition> <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page> . }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
}
