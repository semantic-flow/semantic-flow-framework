              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop> <https://semantic-flow.github.io/semantic-flow-ontology/hasWorkingKnopInventoryFile> <https://semantic-flow.github.io/mesh-alice-bio/alice/_knop/_inventory/inventory.ttl> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
