  "type": "Manifest",
  "id": "urn:accord:semantic-flow:alice-bio:09-alice-bio-referenced-woven",
  "dcterms:title": "Alice Bio 09 alice bio referenced woven",
  "dcterms:description": "Checks the weave over the alice Knop-owned ReferenceCatalog state, including the first catalog history and the advanced alice KnopInventory state while leaving mesh inventory unchanged.",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#weave-alice-reference-catalog",
      "dcterms:title": "Weave alice ReferenceCatalog state",
      "dcterms:description": "Versions the new alice Knop-owned ReferenceCatalog artifact, advances alice KnopInventory to a second historical state, generates the catalog-facing ResourcePages, and leaves mesh inventory unchanged because the new reference surface remains Knop-internal.",
      "fixtureRepo": "github.com/semantic-flow/mesh-alice-bio",
      "operationId": "weave",
      "fromRef": "08-alice-bio-referenced",
      "toRef": "09-alice-bio-referenced-woven",
      "hasFileExpectation": [
        {
          "id": "#alice-bio-ttl",
          "type": "FileExpectation",
          "path": "alice-bio.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#mesh-inventory-ttl",
          "type": "FileExpectation",
          "path": "_mesh/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-meta-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_meta/meta.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/inventory.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-knop-inventory-s2-index",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/_s0002/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-inventory-s2-manifestation-index",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/_s0002/inventory-ttl/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-knop-inventory-s2-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_inventory/_history001/_s0002/inventory-ttl/inventory.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-references-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_references/references.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-references-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_references/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-references-history-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_references/_history001/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-references-state-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_references/_history001/_s0001/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-references-manifestation-page",
          "type": "FileExpectation",
          "path": "alice/_knop/_references/_history001/_s0001/references-ttl/index.html",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#alice-references-snapshot-ttl",
          "type": "FileExpectation",
          "path": "alice/_knop/_references/_history001/_s0001/references-ttl/references.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#alice-bio-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "alice/bio/_knop/_inventory/inventory.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#alice-bio-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#alice-bio-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice> a <https://schema.org/Person> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/alice> <http://xmlns.com/foaf/0.1/knows> <https://semantic-flow.github.io/mesh-alice-bio/bob> . }",
              "expectedBoolean": true
