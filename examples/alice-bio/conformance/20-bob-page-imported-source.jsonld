{
  "@context": {
    "@vocab": "https://spectacular-voyage.github.io/accord/ns#",
    "dcterms": "http://purl.org/dc/terms/",
    "id": "@id",
    "type": "@type",
    "changeType": {
      "@type": "@vocab"
    },
    "compareMode": {
      "@type": "@vocab"
    },
    "targetsFileExpectation": {
      "@type": "@id"
    },
    "ignorePredicate": {
      "@type": "@id"
    }
  },
  "type": "Manifest",
  "id": "urn:accord:semantic-flow:alice-bio:20-bob-page-imported-source",
  "dcterms:title": "Alice Bio 20 bob page imported source",
  "dcterms:description": "Checks the non-woven import-boundary step that imports outside-origin Bob Newhart Markdown into governed artifact bob/page-main, records the remote origin on that governed artifact, and adds Bob page-definition state that points at the governed local artifact rather than the live URL.",
  "hasCase": [
    {
      "type": "TransitionCase",
      "id": "#import-bob-page-main-and-define-bob-page",
      "dcterms:title": "Import Bob Markdown page content and define Bob page source",
      "dcterms:description": "Imports outside-origin Markdown from the raw GitHub URL into governed artifact bob/page-main with local working file bob-page-main.md, updates mesh inventory to register the new artifact, adds bob/_knop/_page/page.ttl that points its main region at bob/page-main in Current mode, and leaves bob/index.html unchanged until weave runs.",
      "fixtureRepo": "github.com/semantic-flow/mesh-alice-bio",
      "operationId": "import",
      "fromRef": "19-alice-page-artifact-source-woven",
      "toRef": "20-bob-page-imported-source",
      "targetDesignatorPath": "bob",
      "hasFileExpectation": [
        {
          "id": "#bob-page-main-md",
          "type": "FileExpectation",
          "path": "bob-page-main.md",
          "changeType": "added",
          "compareMode": "text"
        },
        {
          "id": "#mesh-inventory-ttl",
          "type": "FileExpectation",
          "path": "_mesh/_inventory/inventory.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-page-main-knop-meta-ttl",
          "type": "FileExpectation",
          "path": "bob/page-main/_knop/_meta/meta.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-page-main-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "bob/page-main/_knop/_inventory/inventory.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-knop-page-definition-ttl",
          "type": "FileExpectation",
          "path": "bob/_knop/_page/page.ttl",
          "changeType": "added",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-knop-inventory-ttl",
          "type": "FileExpectation",
          "path": "bob/_knop/_inventory/inventory.ttl",
          "changeType": "updated",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-references-ttl",
          "type": "FileExpectation",
          "path": "bob/_knop/_references/references.ttl",
          "changeType": "unchanged",
          "compareMode": "rdfCanonical"
        },
        {
          "id": "#bob-page",
          "type": "FileExpectation",
          "path": "bob/index.html",
          "changeType": "unchanged",
          "compareMode": "text"
        },
        {
          "id": "#bob-page-main-page",
          "type": "FileExpectation",
          "path": "bob/page-main/index.html",
          "changeType": "absent"
        },
        {
          "id": "#bob-knop-page-definition-page",
          "type": "FileExpectation",
          "path": "bob/_knop/_page/index.html",
          "changeType": "absent"
        }
      ],
      "hasRdfExpectation": [
        {
          "id": "#bob-knop-page-definition-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#bob-knop-page-definition-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page> a <https://semantic-flow.github.io/ontology/core/ResourcePageDefinition> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page#main-region> a <https://semantic-flow.github.io/ontology/core/ResourcePageRegion> ; <https://semantic-flow.github.io/ontology/core/regionKey> \"main\" ; <https://semantic-flow.github.io/ontology/core/hasResourcePageSource> <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page#main-source> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page#main-source> a <https://semantic-flow.github.io/ontology/core/ResourcePageSource> ; <https://semantic-flow.github.io/ontology/core/hasTargetArtifact> <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main> ; <https://semantic-flow.github.io/ontology/core/hasArtifactResolutionMode> <https://semantic-flow.github.io/ontology/core/ArtifactResolutionMode/Current> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page#main-source> <https://semantic-flow.github.io/ontology/core/targetAccessUrl> ?url . }",
              "expectedBoolean": false
            }
          ]
        },
        {
          "id": "#mesh-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#mesh-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/_mesh> <https://semantic-flow.github.io/semantic-flow-ontology/hasKnop> <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main/_knop> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main> a <https://semantic-flow.github.io/semantic-flow-ontology/PayloadArtifact>, <https://semantic-flow.github.io/semantic-flow-ontology/DigitalArtifact> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasWorkingLocatedFile> <https://semantic-flow.github.io/mesh-alice-bio/bob-page-main.md> ; <https://semantic-flow.github.io/ontology/core/workingAccessUrl> \"https://raw.githubusercontent.com/djradon/public-notes/refs/heads/main/user.bob-newhart.md\"^^<http://www.w3.org/2001/XMLSchema#anyURI> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main> <https://semantic-flow.github.io/semantic-flow-ontology/hasArtifactHistory> ?history . }",
              "expectedBoolean": false
            }
          ]
        },
        {
          "id": "#bob-page-main-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#bob-page-main-knop-inventory-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main/_knop> <https://semantic-flow.github.io/semantic-flow-ontology/hasKnopMetadata> <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main/_knop/_meta> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasKnopInventory> <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main/_knop/_inventory> ; <https://semantic-flow.github.io/semantic-flow-ontology/hasPayloadArtifact> <https://semantic-flow.github.io/mesh-alice-bio/bob/page-main> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#bob-knop-inventory-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#bob-knop-inventory-ttl",
          "ignorePredicate": [
            "http://purl.org/dc/terms/created",
            "http://purl.org/dc/terms/updated"
          ],
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop> <https://semantic-flow.github.io/ontology/core/hasResourcePageDefinition> <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_page> . }",
              "expectedBoolean": true
            },
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_inventory/_history001> <https://semantic-flow.github.io/semantic-flow-ontology/latestHistoricalState> <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_inventory/_history001/_s0001> . }",
              "expectedBoolean": true
            }
          ]
        },
        {
          "id": "#bob-references-rdf",
          "type": "RdfExpectation",
          "targetsFileExpectation": "#bob-references-ttl",
          "hasAskAssertion": [
            {
              "type": "SparqlAskAssertion",
              "query": "ASK { <https://semantic-flow.github.io/mesh-alice-bio/bob> <https://semantic-flow.github.io/semantic-flow-ontology/hasReferenceLink> <https://semantic-flow.github.io/mesh-alice-bio/bob/_knop/_references#reference001> . }",
              "expectedBoolean": true
            }
          ]
        }
      ]
    }
  ]
}
