{
  "@context": [
    "https://www.w3.org/ns/hydra/context.jsonld",
    {
      "xsd": "http://www.w3.org/2001/XMLSchema#",
      "sflo": "https://semantic-flow.github.io/semantic-flow-ontology/",
      "sfprov": "https://semantic-flow.github.io/semantic-flow-prov-ontology/",
      "designatorPath": "sflo:designatorPath",
      "referencesUrl": {
        "@id": "https://api.example.org/vocab#referencesUrl",
        "@type": "@id"
      },
      "payloadUrl": {
        "@id": "https://api.example.org/vocab#payloadUrl",
        "@type": "@id"
      },
      "kind": "https://api.example.org/vocab#kind"
    }
  ],
  "@id": "https://example.org/alice/bio/_knop",
  "@type": "sflo:Knop",
  "designatorPath": "alice/bio",
  "referencesUrl": "https://api.example.org/knops/alice/bio/references",
  "payloadUrl": "https://api.example.org/knops/alice/bio/payload",
  "hydra:operation": [
    {
      "@type": "hydra:Operation",
      "hydra:title": "Add reference",
      "hydra:method": "POST",
      "hydra:expects": "https://api.example.org/vocab#KnopAddReferenceJobRequest",
      "hydra:returns": "https://api.example.org/vocab#Job",
      "hydra:target": "https://api.example.org/jobs",
      "kind": "knop.addReference"
    },
    {
      "@type": "hydra:Operation",
      "hydra:title": "Weave this knop",
      "hydra:method": "POST",
      "hydra:expects": "https://api.example.org/vocab#WeaveJobRequest",
      "hydra:returns": "https://api.example.org/vocab#Job",
      "hydra:target": "https://api.example.org/jobs",
      "kind": "weave"
    }
  ]
}
